# Supabase 대시보드 → Project Settings → Database → Connection string (Session pooler, port 5432)
# 예: postgresql://postgres.krwmncolecywlkmlviqu:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres
DATABASE_URL=

# JWT 서명 키 (openssl rand -hex 32 로 생성)
JWT_SECRET=

# 서버 포트
PORT=2567

# 프론트엔드 origin (CORS)
CORS_ORIGIN=http://localhost:3000
