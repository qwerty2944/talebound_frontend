{
  "name": "mud-web-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n web,server -c cyan,magenta \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "npm run dev -w frontend",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
