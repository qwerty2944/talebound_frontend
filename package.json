{
  "name": "mud-web-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n web,backend -c cyan,magenta \"npm:dev:web\" \"npm:dev:backend\"",
    "dev:web": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
